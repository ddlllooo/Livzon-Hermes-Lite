# Hermes-Lite local configuration.
# Copy to .env and fill in deployment-specific values.

# === Main LLM providers ===
XIAOMI_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# === Web search ===
TAVILY_API_KEY=

# === OceanBase (MySQL mode) ===
OCEANBASE_HOST=127.0.0.1
OCEANBASE_PORT=2881
OCEANBASE_USER=root
OCEANBASE_PASSWORD=
OCEANBASE_DATABASE=hermes_lite
OB_POOL_MIN=2
OB_POOL_MAX=10

# === Embedding service ===
EMBEDDING_PROVIDER=zhipu
EMBEDDING_MODEL=embedding-3
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_API_KEY=
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=64
EMBEDDING_TIMEOUT=30

# === Rerank service ===
RERANK_ENABLED=true
RERANK_PROVIDER=bge
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_BASE_URL=http://localhost:9997/v1
RERANK_API_KEY=
RERANK_TIMEOUT=30

# === Retrieval tuning ===
RETRIEVAL_VECTOR_TOP_K=20
RETRIEVAL_BM25_TOP_K=20
RETRIEVAL_RRF_K=60
RETRIEVAL_RERANK_TOP_N=10
RETRIEVAL_FINAL_TOP_N=3
