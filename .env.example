# Hermes-Lite local configuration.
# Copy to .env and fill in deployment-specific values.

# === Dazah Agent adapter ===
# Service-to-service tokens only. Do not put real model provider API keys here
# when Hermes-Lite is deployed as the Dazah central Agent.
HERMES_AGENT_TOKEN=
AGENT_LLM_PROXY_TOKEN=
# Optional: mirror AGENT_LLM_PROXY_TOKEN for config.yaml CLI compatibility.
DAZAH_API_KEY=
DAZAH_API_BASE_URL=http://127.0.0.1:8000/api/v1
DAZAH_AGENT_TOOL_TOKEN=
DAZAH_LLM_BASE_URL=http://127.0.0.1:8000/api/v1/agent/llm
DAZAH_LLM_MODEL=dazah-active-text
# Whole Livzon Agent turn timeout in Hermes-Lite.
HERMES_DAZAH_CHAT_TIMEOUT_SECONDS=180
# Max model/tool-calling iterations for one Livzon Agent turn.
HERMES_DAZAH_MAX_TOOL_ITERATIONS=30

# === Optional direct LLM providers for local standalone development ===
XIAOMI_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# === Web search ===
TAVILY_API_KEY=
